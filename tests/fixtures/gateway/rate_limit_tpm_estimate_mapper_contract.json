  "routing_contract": "rate_limit_tpm_estimate_contract_v1",
  "runtime_scope": "DB-free endpoint request signal mapper only; no reservation acquire, provider attempt, provider key open, upstream call, or billing side effect",
  "trusted_token_signal_boundary": {
    "accepted_material": "numeric trusted prompt/input/completion/total token counts only",
    "raw_material_accepted": false,
    "raw_material_emitted": false,
    "trusted_prompt_tokens_helper": "GatewayTpmEstimateSignals::trusted_prompt_tokens",
    "trusted_input_tokens_helper": "GatewayTpmEstimateSignals::trusted_input_tokens",
    "missing_signal_behavior": "ConservativeFallback",
    "negative_signal_behavior": "sanitize to missing and use fallback",
    "overflow_behavior": "required_tokens_i64 clamps to i64::MAX"
  },
  "trusted_numeric_source_availability_contract": {
