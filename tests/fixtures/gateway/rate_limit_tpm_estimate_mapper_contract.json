      "endpoint": "openai_embeddings",
      "request_numeric_signal": { "trusted_input_tokens": null, "fallback_tokens": -1 },
      "source": "ConservativeFallback",
      "required_tokens": 1024,
      "required_tokens_i64": 1024,
      "used_conservative_fallback": true,
      "sanitized_negative_estimate": true,
