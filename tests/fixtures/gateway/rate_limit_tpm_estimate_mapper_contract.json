    },
    {
      "name": "large_max_output_saturates_to_i64",
      "endpoint": "gemini_native",
      "request_numeric_signal": { "generationConfig.maxOutputTokens": "u64_greater_than_i64_max" },
      "trusted_prompt_tokens": 1,
      "max_completion_tokens": 9223372036854775807,
      "source": "PromptAndMaxCompletion",
      "required_tokens_i64": 9223372036854775807,
      "clamped_to_i64_max": true
    },
    {
      "name": "zero_prompt_and_zero_max_output_clamps_to_one",
      "endpoint": "openai_chat",
      "request_numeric_signal": { "max_completion_tokens": 0 },
      "trusted_prompt_tokens": 0,
      "max_completion_tokens": 0,
      "source": "PromptAndMaxCompletion",
      "required_tokens": 1,
      "required_tokens_i64": 1,
      "used_conservative_fallback": false
    }
  ],
  "safe_summary_fields": [
    "schema",
    "endpoint",
    "source",
    "required_tokens",
    "required_tokens_i64",
    "prompt_tokens",
    "completion_tokens",
    "max_completion_tokens",
    "completion_reservation_tokens",
    "fallback_tokens",
    "used_conservative_fallback",
    "sanitized_negative_estimate",
    "clamped_to_i64_max"
  ],
  "side_effect_contract": {
    "reservation_acquire": false,
    "provider_attempt": false,
    "provider_key_open": false,
    "upstream_call": false,
    "billing_side_effect": false
  },
  "forbidden_output_markers": [
    "sk-live",
    "authorization",
    "bearer",
    "provider_key",
    "api_key",
    "encrypted_secret",
    "payload",
    "request_body",
    "raw_prompt",
    "raw_completion",
    "raw_header",
    "current_window_state",
    "messages",
    "contents",
    "input"
  ]
}
