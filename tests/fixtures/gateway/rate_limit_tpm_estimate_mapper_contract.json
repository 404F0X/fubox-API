      "source": "PromptAndMaxCompletion",
      "required_tokens": 812,
      "required_tokens_i64": 812,
      "used_conservative_fallback": false
    },
    {
      "name": "gemini_native_max_output_tokens",
      "endpoint": "gemini_native",
      "request_numeric_signal": { "generationConfig.maxOutputTokens": 256 },
      "trusted_prompt_tokens": 90,
      "max_completion_tokens": 256,
      "source": "PromptAndMaxCompletion",
      "required_tokens": 346,
      "required_tokens_i64": 346,
      "used_conservative_fallback": false
    },
    {
      "name": "missing_tokenizer_and_missing_max_output",
