      "request_numeric_signal": {},
      "trusted_prompt_tokens": null,
      "max_completion_tokens": null,
      "source": "ConservativeFallback",
      "required_tokens": 256,
      "required_tokens_i64": 256,
      "used_conservative_fallback": true
    },
    {
      "name": "missing_tokenizer_with_max_output",
