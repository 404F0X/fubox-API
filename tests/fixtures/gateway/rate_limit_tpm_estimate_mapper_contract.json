      "trusted_prompt_tokens": null,
      "max_completion_tokens": 128,
      "source": "PartialEstimateWithConservativeFallback",
      "required_tokens": 384,
      "required_tokens_i64": 384,
      "used_conservative_fallback": true
    },
    {
      "name": "openai_embeddings_missing_tokenizer",
      "endpoint": "openai_embeddings",
      "request_numeric_signal": {},
      "trusted_prompt_tokens": null,
      "max_completion_tokens": null,
