      "required_tokens": 256,
      "required_tokens_i64": 256,
      "used_conservative_fallback": true,
      "raw_input_emitted": false
    },
    {
      "name": "trusted_prompt_tokens_with_max_output",
      "endpoint": "openai_chat",
      "request_numeric_signal": { "trusted_prompt_tokens": 200, "max_completion_tokens": 400 },
      "source": "PromptAndMaxCompletion",
      "required_tokens": 600,
      "required_tokens_i64": 600,
