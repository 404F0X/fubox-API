{
  "scenario": "gateway_openai_responses_stream_runtime_contract_v1",
  "endpoint": {
    "name": "responses_stream",
    "path": "POST /v1/responses",
    "stream": true,
    "runtime_entry": "apps/gateway/src/streaming.rs::responses_streaming",
    "previous_501_removed": true
  },
  "request_flow": [
    "authenticate_virtual_key",
    "parse_openai_response_request",
    "resolve_canonical_model",
    "select_route_candidates",
    "create_request_started",
    "pre_authorize_before_provider_attempt",
    "create_provider_attempt_started",
    "open_provider_key_for_route",
    "responses_stream_with_provider_key",
    "stream_response"
  ],
  "provider_contract": {
    "adapter": "OpenAiCompatibleClient",
    "upstream_call": "responses_stream_with_provider_key",
    "upstream_path": "/v1/responses",
    "upstream_model_rewrite": "responses_request_for_upstream",
    "provider_key_header": "Authorization: Bearer <provider-key>",
    "provider_key_secret_logged": false,
    "authorization_logged": false
  },
  "stream_contract": {
    "protocol": "openai_responses",
    "content_type": "text/event-stream",
    "pull_model": "one_upstream_chunk_per_downstream_poll",
    "max_upstream_chunk_bytes": 4194304,
    "max_sse_event_bytes": 4194304,
    "no_late_fallback_after_response_start": true,
    "downstream_body_drop_end_reason": "client_cancel"
  },
  "terminal_contract": {
    "completed": {
      "request_status": "succeeded",
      "provider_attempt_status": "succeeded",
      "stream_end_reason": "completed",
      "usage_source": "response.completed usage",
      "rating_and_settle": "when completed terminal has complete usage and non-zero rating"
    },
    "failed_or_error_terminal": {
      "request_status": "partial_or_failed",
      "provider_attempt_status": "failed",
      "stream_end_reason": "upstream_error",
      "late_fallback": false,
      "usage_billed": false
    },
    "invalid_json_event": {
      "request_status": "partial_or_failed",
      "provider_attempt_status": "failed",
      "stream_end_reason": "parser_error",
      "late_fallback": false,
      "usage_billed": false
    }
  },
  "forbidden_markers": [
    "sk-live",
    "plain-provider-secret",
    "provider-secret-value",
    "payload body secret"
  ],
  "notes": "Dry-run/source contract for the first Gateway OpenAI Responses streaming runtime slice. Live mock-provider scenarios are still pending; this fixture locks no 501, preauth/provider side-effect order, OpenAI-compatible stream adapter usage, Responses terminal usage/rating semantics, and secret-safe output."
}
