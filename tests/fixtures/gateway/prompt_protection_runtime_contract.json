{
  "scenario": "gateway_prompt_protection_runtime_contract_v1",
  "endpoint": {
    "name": "chat_completions",
    "path": "POST /v1/chat/completions",
    "streaming_supported": true,
    "runtime_entry": "apps/gateway/src/main.rs::chat_completions"
  },
  "covered_endpoints": [
    {
      "name": "chat_completions",
      "path": "POST /v1/chat/completions",
      "streaming_supported": true,
      "runtime_entry": "apps/gateway/src/main.rs::chat_completions",
      "preflight_marker": "prompt_protection_rejection_for_chat_request"
    },
    {
      "name": "responses",
      "path": "POST /v1/responses",
      "streaming_supported": true,
      "runtime_entry": "apps/gateway/src/main.rs::responses",
      "preflight_marker": "prompt_protection_rejection_for_responses_request"
    },
    {
      "name": "embeddings",
      "path": "POST /v1/embeddings",
      "streaming_supported": false,
      "runtime_entry": "apps/gateway/src/main.rs::embeddings",
      "preflight_marker": "prompt_protection_rejection_for_embeddings_request"
    },
    {
      "name": "anthropic_messages",
      "path": "POST /v1/messages",
      "streaming_supported": true,
      "runtime_entry": "apps/gateway/src/main.rs::anthropic_messages",
      "preflight_marker": "prompt_protection_rejection_for_anthropic_messages_request"
    },
    {
      "name": "gemini_generate_content_native_passthrough",
      "path": "POST /v1beta/models/{model}:generateContent|:streamGenerateContent",
      "streaming_supported": true,
      "runtime_entry": "apps/gateway/src/main.rs::gemini_generate_content_native_passthrough",
      "preflight_marker": "prompt_protection_rejection_for_gemini_native_request"
    }
  ],
  "runtime_policy": {
    "env": "AI_GATEWAY_PROMPT_PROTECTION",
    "config_json_env": "AI_GATEWAY_PROMPT_PROTECTION_CONFIG_JSON",
    "yaml_config_path": "security.prompt_protection",
    "source_precedence": [
      "AI_GATEWAY_PROMPT_PROTECTION_CONFIG_JSON",
      "security.prompt_protection",
      "AI_GATEWAY_PROMPT_PROTECTION",
      "default"
    ],
    "legacy_mode_env_scope": "fallback_only_when_yaml_config_is_default_and_json_env_is_absent",
    "default": "enforce",
    "modes": ["enforce", "audit", "disabled"],
    "rule_matching": "bounded_no_per_request_regex",
    "config_parse_boundary": "startup",
    "custom_rules_schema": "prompt_protection_rules_v1",
    "max_config_json_bytes": 16384,
    "default_rules_enabled_by_default": true,
    "custom_rules_compiled_before_requests": true,
    "per_request_config_parse": false
  },
  "request_flow": {
    "chat_completions": [
      "authenticate_virtual_key",
      "parse_chat_completion_request",
      "compute_request_body_hash",
      "prompt_protection_preflight",
      "resolve_canonical_model",
      "select_route_candidates",
      "create_request_started",
      "pre_authorize_before_provider_attempt",
      "create_provider_attempt_started",
      "open_provider_key_for_route",
      "upstream_call"
    ],
    "responses": [
      "authenticate_virtual_key",
      "parse_responses_request",
      "compute_request_body_hash",
      "prompt_protection_preflight",
      "resolve_canonical_model",
      "select_route_candidates",
      "create_request_started",
      "responses_streaming_or_provider_attempt",
      "pre_authorize_before_provider_attempt",
      "create_provider_attempt_started",
      "open_provider_key_for_route",
      "upstream_call"
    ],
    "embeddings": [
      "authenticate_virtual_key",
      "parse_embeddings_request",
      "compute_request_body_hash",
      "prompt_protection_preflight",
      "resolve_canonical_model",
      "select_route_candidates",
      "create_request_started",
      "pre_authorize_before_provider_attempt",
      "create_provider_attempt_started",
      "open_provider_key_for_route",
      "upstream_call"
    ],
    "anthropic_messages": [
      "authenticate_virtual_key",
      "parse_anthropic_messages_request",
      "compute_request_body_hash",
      "prompt_protection_preflight",
      "resolve_canonical_model",
      "select_route_candidates",
      "create_request_started",
      "anthropic_messages_streaming_or_provider_attempt",
      "pre_authorize_before_provider_attempt",
      "create_provider_attempt_started",
      "open_provider_key_for_route",
      "upstream_call"
    ],
    "gemini_generate_content_native_passthrough": [
      "authenticate_virtual_key",
      "parse_gemini_native_path",
      "compute_request_body_hash",
      "parse_native_json_body",
      "validate_native_body_routing_fields",
      "prompt_protection_preflight",
      "resolve_canonical_model",
      "select_route_candidates",
      "create_request_started",
      "gemini_streaming_or_provider_attempt",
      "pre_authorize_before_provider_attempt",
      "create_provider_attempt_started",
      "open_provider_key_for_route",
      "upstream_call"
    ]
  },
  "rejected_contract": {
    "http_status": 400,
    "openai_error": {
      "code": "prompt_protection_rejected",
      "gateway_stage": "request_preflight"
    },
    "request_logs": {
      "created": true,
      "final_status": "rejected",
      "request_body_hash_required": true,
      "payload_log_storage_mode": "hash_only",
      "payload_preview_stored": false,
      "payload_body_stored": false,
      "route_snapshot_prompt_protection_fields": [
        "schema",
        "mode",
        "action",
        "detected_action",
        "effective_action",
        "reason",
        "hit_count",
        "default_hit_count",
        "configured_hit_count",
        "scopes",
        "hit_kinds",
        "configured_actions",
        "configured_pattern_types",
        "configured_rules",
        "raw_payload_omitted",
        "raw_pattern_values_omitted"
      ]
    },
    "provider_attempts": {
      "created": false
    },
    "upstream_call": {
      "provider_key_opened": false,
      "http_request_sent": false
    }
  },
  "http_repository_regressions": [
    {
      "name": "chat_completions_reject_no_provider_side_effects",
      "endpoint": "POST /v1/chat/completions",
      "test": "apps/gateway/src/main.rs::tests::prompt_protection_http_reject_logs_request_without_provider_side_effects",
      "assertions": [
        "block_response_prompt_protection_rejected",
        "request_log_created_and_finished_rejected",
        "provider_attempt_started_count_zero",
        "provider_key_open_count_zero",
        "upstream_call_count_zero",
        "payload_log_hash_only",
        "route_snapshot_prompt_protection_sanitized"
      ],
      "forbidden_logged_fields": [
        "raw_prompt",
        "raw_pattern",
        "authorization_header",
        "cookie_header",
        "provider_key_secret"
      ]
    },
    {
      "name": "responses_reject_no_provider_side_effects",
      "endpoint": "POST /v1/responses",
      "test": "apps/gateway/src/main.rs::tests::prompt_protection_responses_http_reject_logs_request_without_provider_side_effects",
      "assertions": [
        "block_response_prompt_protection_rejected",
        "request_log_created_and_finished_rejected",
        "provider_attempt_started_count_zero",
        "provider_key_open_count_zero",
        "upstream_call_count_zero",
        "payload_log_hash_only",
        "route_snapshot_prompt_protection_sanitized"
      ],
      "forbidden_logged_fields": [
        "raw_prompt",
        "raw_pattern",
        "authorization_header",
        "cookie_header",
        "provider_key_secret"
      ]
    },
    {
      "name": "anthropic_messages_reject_no_provider_side_effects",
      "endpoint": "POST /v1/messages",
      "test": "apps/gateway/src/main.rs::tests::prompt_protection_anthropic_http_reject_logs_request_without_provider_side_effects",
      "assertions": [
        "block_response_prompt_protection_rejected",
        "request_log_created_and_finished_rejected",
        "provider_attempt_started_count_zero",
        "provider_key_open_count_zero",
        "upstream_call_count_zero",
        "payload_log_hash_only",
        "route_snapshot_prompt_protection_sanitized"
      ],
      "forbidden_logged_fields": [
        "raw_prompt",
        "raw_pattern",
        "authorization_header",
        "cookie_header",
        "provider_key_secret"
      ]
    }
  ],
  "audit_contract": {
    "mode": "audit",
    "rejects": false,
    "audit_before_provider_attempt": true,
    "logged_fields": [
      "request_body_hash",
      "prompt_protection_action",
      "prompt_protection_reason",
      "prompt_protection_hit_count"
    ],
    "forbidden_logged_fields": [
      "raw_payload",
      "authorization",
      "provider_key_secret",
      "message_content",
      "request_body"
    ]
  },
  "forbidden_markers": [
    "Ignore previous instructions",
    "sk-live-secret",
    "Authorization: Bearer",
    "Cookie: session",
    "ticket-[0-9]{4}",
    "provider-secret-value"
  ],
  "notes": "Gateway chat, responses, embeddings, Anthropic messages, and Gemini native generateContent prompt protection runs after auth/body parse and before canonical routing, request_started, provider_attempts, provider key opening, and upstream calls. Chat, responses, Anthropic messages, and Gemini native generateContent cover stream=true requests through their shared preflight; embeddings is non-stream. Enforce rejects with hash-only request logging plus bounded action/reason/hit summary. Audit logs only the hash and summary before continuing."
}
