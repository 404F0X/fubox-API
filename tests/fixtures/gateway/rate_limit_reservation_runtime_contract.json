{
  "scenario": "gateway_rate_limit_reservation_runtime_contract_v1",
  "crate": "apps/gateway",
  "runtime_schema": "gateway_rate_limit_reservation_runtime_v1",
  "backend": "request_local_plan",
  "db_execution": {
    "schema": "gateway_rate_limit_reservation_db_execution_v1",
    "backend": "db_key_window_counters",
    "acquire_order": "after selected route provider key id is known and before provider_attempt/provider key open/upstream",
    "release_order": "before provider attempt final metadata on fallback/error and stream non-completed finalization",
    "release_on_completed": false,
    "double_release_prevented": true
  },
  "contract": {
    "reservation_backend": "request-local planning plus DB provider key counter execution",
    "acquire_order": "after preauth and before provider attempt side effects",
    "finalize_order": "provider attempt error, fallback, stream non-completed finalizer, or stream pre-response error",
    "bounded_dimensions": [
      "rpm",
      "tpm",
      "concurrency"
    ],
    "missing_limited_counter": {
      "acquire_status": "rejected",
      "finalize_status": "release_noop",
      "request_rejected_before_upstream": true
    },
    "reservation_reject_fallback": {
      "skip_schema": "gateway_rate_limit_reservation_skip_v1",
      "final_rejection_schema": "gateway_rate_limit_reservation_rejection_v1",
      "skip_reason": "rate_limit_reservation_rejected",
      "skip_action": "try_next_route",
      "skip_before_provider_attempt": true,
      "try_next_route_when_present": true,
      "final_error_when_all_candidates_reject": "rate_limit_exceeded",
      "final_rejection_route_selected": false
    },
    "stores_request_or_response_body": false,
    "stores_authorization_material": false,
    "stores_provider_key": false,
    "stores_raw_headers": false,
    "stores_raw_endpoint": false,
    "adds_metrics_labels": false
  },
  "expected": {
    "successful_acquire_status": "acquired",
    "successful_finalize_status": "released",
    "successful_counter_updates_planned": 3,
    "db_acquire_applied_status": "applied",
    "db_acquire_not_applied_status": "not_applied",
    "db_acquire_noop_status": "noop",
    "db_release_applied_status": "applied",
    "missing_window_acquire_status": "rejected",
    "missing_window_finalize_status": "release_noop",
    "reservation_reject_skip_schema": "gateway_rate_limit_reservation_skip_v1",
    "reservation_final_rejection_schema": "gateway_rate_limit_reservation_rejection_v1",
    "reservation_reject_skip_reason": "rate_limit_reservation_rejected",
    "reservation_reject_skip_action": "try_next_route"
  },
  "tpm_estimate_bridge": {
    "schema": "gateway_tpm_estimate_mapper_v1",
    "conservative_fallback_tokens": 1024,
    "partial_source": "PartialEstimateWithConservativeFallback",
    "fallback_source": "ConservativeFallback",
    "openai_chat_partial_required_tokens": 1152,
    "openai_responses_partial_required_tokens": 1324,
    "anthropic_messages_partial_required_tokens": 1536,
    "gemini_native_partial_required_tokens": 1280,
    "missing_max_required_tokens": 1024,
