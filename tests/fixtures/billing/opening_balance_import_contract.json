        "operation",
        "external_source",
        "external_reference_id",
        "reason"
      ],
      "raw_idempotency_key_output_allowed": false,
      "raw_import_payload_output_allowed": false
    },
    "direct_wallet_snapshot_mutation_allowed": false,
    "contract_runtime_wiring": "not_runtime_wired"
  },
  "runtime_schema_contract": {
    "requires_schema": true,
    "runtime_implemented": false,
    "table": "opening_balance_imports",
    "required_columns": [
      "id",
      "tenant_id",
      "project_id",
      "wallet_id",
      "currency",
      "opening_amount",
      "external_source",
      "external_reference_id",
      "idempotency_key",
      "status",
      "ledger_entry_id",
      "admin_adjustment_entry_id",
      "audit_id",
      "request_summary",
      "created_at",
      "updated_at"
    ],
    "required_unique_constraints": [
      "(tenant_id,idempotency_key)",
      "(tenant_id,external_source,external_reference_id)"
    ],
    "required_statuses": [
      "imported",
      "replayed",
      "refused"
    ],
    "required_replay_fields": [
      "opening_import_id",
      "ledger_entry_id",
      "admin_adjustment_entry_id",
      "audit_id",
      "status",
      "request_summary"
    ],
    "required_conflict_guards": [
      "idempotency_replay_same_body",
      "idempotency_conflict_same_key_different_body",
      "external_reference_conflict_different_key",
      "wallet_currency_mismatch_refusal"
    ],
    "schema_contract_compatible": true,
    "e11_schema_landed": true
  },
  "runtime_acceptance_contract": {
    "route_or_internal_runtime_invoked_required": true,
    "psql_plan_not_runtime_acceptance": true,
    "rollback_contained_psql_plan_allowed_as_blocked_evidence": true,
    "runtime_implemented_requires_live_readback": true,
