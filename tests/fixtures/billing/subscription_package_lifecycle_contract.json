  "schema_contract": {
    "schema_contract_version": "subscription_package_lifecycle_schema_contract.v1",
    "runtime_implemented": false,
    "contract_only": true,
    "paid_gate_changed": false,
    "migration_required": true,
    "draft_migration_path": "db/migrations/TODO-32K_subscription_package_lifecycle.sql",
    "tables": [
      {
        "name": "subscription_plans",
        "required": true,
        "purpose": "durable product plan definition",
        "required_columns": [
          "id",
          "tenant_id",
          "plan_code",
          "display_name",
          "status",
          "currency",
          "billing_interval",
          "unit_price",
          "included_credit_amount",
          "metadata",
          "created_at",
          "updated_at"
        ],
        "money_decimal_columns": [
          "unit_price",
          "included_credit_amount"
        ],
        "unique_constraints": [
          "unique(tenant_id, plan_code)"
        ],
        "foreign_keys": [
          "tenant_id -> tenants.id"
        ],
        "secret_safe_columns": [
          "metadata"
        ]
      },
      {
        "name": "subscription_packages",
        "required": true,
        "purpose": "package/entitlement grouping linked to a plan",
        "required_columns": [
          "id",
          "tenant_id",
          "plan_id",
          "package_code",
          "status",
          "entitlement_summary",
          "metadata",
          "created_at",
          "updated_at"
        ],
        "unique_constraints": [
          "unique(tenant_id, package_code)"
        ],
        "foreign_keys": [
          "tenant_id, plan_id -> subscription_plans.tenant_id, id"
        ],
        "secret_safe_columns": [
          "metadata",
          "entitlement_summary"
        ]
      },
      {
        "name": "subscriptions",
        "required": true,
        "purpose": "durable subscription state and current billing period",
        "required_columns": [
          "id",
          "tenant_id",
          "project_id",
          "wallet_id",
          "plan_id",
          "package_id",
          "status",
          "currency",
          "current_period_start",
          "current_period_end",
          "trial_ends_at",
          "paused_at",
          "cancelled_at",
          "idempotency_fingerprint",
          "latest_credit_grant_id",
          "latest_ledger_entry_id",
          "latest_invoice_id",
          "latest_order_id",
          "metadata",
          "created_at",
          "updated_at"
        ],
        "unique_constraints": [
          "unique(tenant_id, idempotency_fingerprint)"
        ],
        "foreign_keys": [
          "tenant_id, wallet_id -> wallets.tenant_id, id",
          "tenant_id, plan_id -> subscription_plans.tenant_id, id",
          "tenant_id, package_id -> subscription_packages.tenant_id, id",
          "tenant_id, latest_credit_grant_id -> credit_grants.tenant_id, id",
          "tenant_id, latest_ledger_entry_id -> ledger_entries.tenant_id, id"
        ],
        "secret_safe_columns": [
          "metadata"
        ]
      },
      {
        "name": "subscription_events_or_schedules",
        "required": true,
        "purpose": "renewal/proration/dunning/refusal/audit readback and scheduler intent",
        "required_columns": [
          "id",
          "tenant_id",
          "subscription_id",
          "event_type",
          "event_status",
          "effective_at",
          "idempotency_fingerprint",
          "credit_grant_id",
          "ledger_entry_id",
          "invoice_id",
          "order_id",
          "audit_id",
          "refusal_code",
          "request_summary",
          "metadata",
          "created_at",
          "updated_at"
        ],
        "unique_constraints": [
          "unique(tenant_id, idempotency_fingerprint)"
        ],
        "foreign_keys": [
          "tenant_id, subscription_id -> subscriptions.tenant_id, id",
          "tenant_id, credit_grant_id -> credit_grants.tenant_id, id",
          "tenant_id, ledger_entry_id -> ledger_entries.tenant_id, id",
          "tenant_id, audit_id -> audit_logs.tenant_id, id"
        ],
        "secret_safe_columns": [
          "request_summary",
          "metadata"
        ]
      }
    ],
    "required_relationships": [
      "subscription credit issuance links to credit_grants.id or ledger_entries.id",
      "renewal and activation link to bounded invoice_id and order_id references",
      "refusal events write no credit_grants, ledger_entries, invoice, or order rows",
      "audit_id is present for accepted lifecycle events and bounded refusal records",
      "wallet balance snapshot is never directly mutated as accounting truth"
    ],
    "invariants": [
      "idempotency_fingerprint is stored hashed or otherwise non-raw",
      "same idempotency key and same body replays original subscription/event ids",
      "same idempotency key and different body refuses without new writes",
      "amount and price fields use fixed decimal strings and SQL numeric scale 8",
      "currency mismatch and invalid plan refusals produce no accounting writes",
      "metadata and request_summary omit raw provider payloads, tokens, DB URLs, voucher codes, and secrets"
    ]
  },
  "money_contract": {
    "format": "decimal_string_with_currency",
    "scale": 8,
    "float_allowed": false
