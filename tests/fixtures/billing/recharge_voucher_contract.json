    "reusable_primitives": [
      {
        "primitive": "wallets",
        "status": "available",
        "usage": "voucher redeem and recharge credit effects must validate tenant/project/wallet ownership and currency before any accounting write"
      },
      {
        "primitive": "credit_grants",
        "status": "available",
        "usage": "successful voucher redeem or paid recharge can issue spendable credit through credit grant rows"
      },
      {
        "primitive": "ledger_entries_admin_adjustment",
        "status": "available",
        "usage": "recharge paid, voucher redeem, refund, cancel, and reversal effects can map to ledger/admin adjustment entries"
      },
      {
        "primitive": "audit_logs",
        "status": "available",
        "usage": "voucher issue/redeem/refusal and recharge state transitions require bounded audit ids"
      },
      {
        "primitive": "opening_balance_import_idempotent_transaction_pattern",
        "status": "available",
        "usage": "same-key replay, same-key conflict refusal, duplicate reference refusal, and no-write refusal transaction shape can be reused"
      },
      {
        "primitive": "credit_grant_crud_runtime",
        "status": "available",
        "usage": "grant create/revoke/expire readback can be reused for redeem success and refund/cancel reversal"
      },
      {
        "primitive": "remaining_balance_read_model",
        "status": "available",
        "usage": "accepted voucher/recharge credit effects should appear in remaining balance readback"
      }
    ],
    "missing_primitives": [
      {
        "primitive": "recharge_intents_schema",
        "required": true,
        "reason": "top-up intent lifecycle, payment handoff state, capture/refund/cancel idempotency, and provider references need durable rows"
      },
      {
        "primitive": "voucher_campaigns_schema",
        "required": true,
        "reason": "campaign scope, currency, amount, validity window, max redemptions, and revoke status need durable rows"
      },
      {
        "primitive": "voucher_issuances_schema",
        "required": true,
        "reason": "issued vouchers need code hash, redacted preview, campaign linkage, status, and audit/readback ids without raw code storage"
      },
      {
        "primitive": "voucher_redemptions_schema",
        "required": true,
        "reason": "redeem success, replay, same-code conflicts, grant/ledger linkage, and redeemer ownership need durable idempotent rows"
      },
      {
        "primitive": "voucher_redeem_attempts_or_abuse_events_schema",
        "required": true,
        "reason": "failed redeem attempts, rate-limit windows, and abuse refusals need persistence without leaking raw code"
      },
      {
        "primitive": "payment_provider_handoff_and_callback_state",
        "required": true,
        "reason": "recharge capture/refund/cancel requires provider state, redacted references, and callback/reconciliation readback"
      },
      {
        "primitive": "live_route_matrix_artifact",
        "required": true,
        "reason": "QA runtime acceptance needs non-contract route/internal invocation plus readback for issue/redeem/replay/refusal/refund/audit"
      }
    ],
