{
  "scenario": "rate_limit_tpm_estimate_contract",
  "crate": "ai-gateway-routing",
  "schema": "rate_limit_tpm_estimate_contract_v1",
  "function": "estimate_tpm_reservation",
  "input_contract": {
    "prompt_tokens": "optional non-negative integer tokenizer estimate for prompt/input tokens",
    "completion_tokens": "optional non-negative integer planned completion token estimate",
    "max_completion_tokens": "optional non-negative integer max completion bound; used when larger than completion_tokens",
    "total_tokens": "optional non-negative integer full request token reservation estimate; preferred when present",
    "conservative_fallback_tokens": "positive integer fallback reservation used when tokenizer/usage data is missing"
  },
  "stable_behaviors": [
    {
      "name": "total_tokens_preferred",
