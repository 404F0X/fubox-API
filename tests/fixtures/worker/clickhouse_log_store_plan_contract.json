{
  "contract": "clickhouse_log_store_worker_plan.v1",
  "commands": {
    "dry_run": "ai-worker clickhouse-log-store --dry-run --input tests/fixtures/worker/clickhouse_log_store_plan_contract.json",
    "execute": "ai-worker clickhouse-log-store --execute --force --input tests/fixtures/worker/clickhouse_log_store_plan_contract.json"
  },
  "input": {
    "tenant_id": "00000000-0000-0000-0000-000000000001",
    "env": {
      "AI_GATEWAY_CLICKHOUSE_LOG_STORE_ENABLED": "true",
      "AI_GATEWAY_CLICKHOUSE_ENDPOINT": "https://clickhouse.example.com:8443",
      "AI_GATEWAY_CLICKHOUSE_DATABASE": "prod_logs",
      "AI_GATEWAY_CLICKHOUSE_TABLE": "gateway_events",
      "AI_GATEWAY_CLICKHOUSE_BATCH_SIZE": "2500",
      "AI_GATEWAY_CLICKHOUSE_FLUSH_INTERVAL_MS": "750",
      "AI_GATEWAY_CLICKHOUSE_TLS_VERIFY": "false",
      "AI_GATEWAY_CLICKHOUSE_USERNAME": "ops-user",
      "AI_GATEWAY_CLICKHOUSE_PASSWORD": "plain-password",
      "AI_GATEWAY_CLICKHOUSE_TOKEN": "fixture-api-secret",
      "AI_GATEWAY_CLICKHOUSE_AUTHORIZATION": "Bearer fixture-bearer-secret",
      "AI_GATEWAY_CLICKHOUSE_BACKPRESSURE_MAX_QUEUE_ROWS": "42",
      "AI_GATEWAY_CLICKHOUSE_BACKPRESSURE_DROP_POLICY": "drop_oldest",
      "AI_GATEWAY_CLICKHOUSE_RETRY_MAX_ATTEMPTS": "5",
      "AI_GATEWAY_CLICKHOUSE_RETRY_INITIAL_BACKOFF_MS": "200",
      "AI_GATEWAY_CLICKHOUSE_RETRY_MAX_BACKOFF_MS": "4000",
      "AI_GATEWAY_CLICKHOUSE_PAYLOAD_POLICY": "redacted"
    }
  },
  "expected_output_contract": {
    "schema_version": "clickhouse_log_store_worker_plan.v1",
    "dry_run": true,
    "mode": "plan_only",
    "read_only": true,
    "runtime_connected": false,
    "db_reads": false,
    "db_writes": false,
    "queue_writes": false,
    "file_system_writes": false,
    "outbound_calls": false,
    "network_requests": false,
    "clickhouse_config": {
      "contract": "clickhouse_log_store_plan_v1",
      "enabled": true,
      "endpoint": "https://clickhouse.example.com:8443",
      "database": "prod_logs",
      "table": "gateway_events"
    },
    "queue": {
      "queue_type": "bounded_in_memory_future",
      "max_queue_rows": 42,
      "batch_size": 2500,
      "flush_interval_ms": 750,
      "bounded_memory": true
    },
    "durable_queue": {
      "queue_type": "append_only_wal_future",
      "planned": true,
      "enabled_in_this_slice": false,
      "execute_supported": false,
      "file_system_writes": false,
      "wal_directory": {
        "root": "AI_GATEWAY_CLICKHOUSE_WAL_DIR or <data_dir>/clickhouse-log-store/wal",
        "tenant_partition": "tenant_id=00000000-0000-0000-0000-000000000001",
        "segment_pattern": "wal-{monotonic_sequence}.jsonl",
        "checkpoint_file": "checkpoint.json",
        "creates_directories": false,
        "writes_files": false
      },
      "wal_record_shape": {
        "encoding": "json_lines",
        "status_values": [
          "pending",
          "leased",
          "acked",
          "retry",
          "dead_letter"
        ],
        "fields": [
          "wal_sequence",
          "tenant_id",
          "sink",
          "source_relation",
          "source_record_id",
          "request_id",
          "provider_attempt_id",
          "event_id",
          "dedup_key",
          "payload_hash",
          "payload_policy",
          "record_hash",
          "status",
          "attempt",
          "not_before_utc",
          "created_at_utc",
          "updated_at_utc",
          "metadata_redacted"
        ],
        "payload_body_written": false,
        "credential_material_written": false
      },
      "disk_budget": {
        "bounded_disk": true,
        "max_bytes": 536870912,
        "max_segment_bytes": 16777216,
        "max_segments": 32,
        "max_unacked_records": 42,
        "overflow_action": "evict_oldest_unflushed_record"
      },
      "enqueue": {
        "operation": "enqueue",
        "idempotency_key_fields": [
          "tenant_id",
          "sink",
          "dedup_key",
          "record_hash"
        ],
        "status_from": [
          "missing"
        ],
        "status_to": "pending",
        "transaction_boundary": "append_wal_record_then_update_dedup_journal_future"
      },
      "dequeue": {
        "operation": "dequeue",
        "idempotency_key_fields": [
          "tenant_id",
          "wal_sequence",
          "lease_id"
        ],
        "status_from": [
          "pending",
          "retry"
        ],
        "status_to": "leased",
        "transaction_boundary": "lease_batch_before_clickhouse_send_future"
      },
      "ack": {
        "operation": "ack",
        "idempotency_key_fields": [
          "tenant_id",
          "wal_sequence",
          "sink",
          "dedup_key"
        ],
        "status_from": [
          "leased"
        ],
        "status_to": "acked",
        "transaction_boundary": "ack_after_clickhouse_insert_and_dedup_confirm_future"
      },
      "retry": {
        "idempotency_key_fields": [
          "tenant_id",
          "wal_sequence",
          "attempt"
        ],
        "max_attempts": 5,
        "initial_backoff_ms": 200,
        "max_backoff_ms": 4000,
        "retry_status": "retry",
        "exhausted_status": "dead_letter"
      },
      "retention": {
        "delete_acked_segments_after_seconds": 86400,
        "delete_failed_segments_after_seconds": 604800,
        "checkpoint_after_acked_records": 2500,
        "requires_no_pending_records_before_segment_delete": true
      },
      "load_safety": {
        "replay_order": "tenant_partition_then_wal_sequence",
        "max_replay_batch_rows": 2500,
        "max_replay_bytes": 4194304,
        "single_consumer_lock": "advisory_file_lock_future",
        "replay_requires_dedup_journal_check": true,
        "payload_policy_enforced_before_enqueue": true
      },
      "dedup_journal_linkage": {
        "journal_relation": "clickhouse_log_store_dedup_journal_future",
        "journal_key_fields": [
          "tenant_id",
          "sink",
          "dedup_key"
        ],
        "wal_link_fields": [
          "tenant_id",
          "wal_sequence",
          "record_hash",
          "payload_hash"
        ],
        "conflict_action": "skip_duplicate_same_record_hash",
        "payload_hash_mismatch_action": "dead_letter_and_require_manual_review_future"
      }
    },
    "backpressure": {
      "drop_policy": "drop_oldest",
      "overflow_action": "evict_oldest_unflushed_record"
    },
    "dedup": {
      "enabled": true,
      "strategy": "stable_idempotency_key",
      "conflict_action": "skip_duplicate_same_hash"
    },
    "table_mapping": [
      {
        "sink": "request_logs",
        "qualified_target_table": "prod_logs.gateway_events_request_logs",
        "dedup_key_fields": [
          "tenant_id",
          "request_id"
        ]
      },
      {
        "sink": "provider_attempts",
        "qualified_target_table": "prod_logs.gateway_events_provider_attempts",
        "dedup_key_fields": [
          "tenant_id",
          "request_id",
          "provider_attempt_id"
        ]
      },
      {
        "sink": "event_log",
        "qualified_target_table": "prod_logs.gateway_events_event_log",
        "dedup_key_fields": [
          "tenant_id",
          "event_id",
          "event_type"
        ]
      }
    ]
  },
  "safety_contract": {
    "db_reads": false,
    "db_writes": false,
    "clickhouse_network_requests": false,
    "queue_writes": false,
    "file_system_writes": false,
    "wal_file_writes": false,
    "env_values_output": false,
    "credential_material_output": false,
    "payload_body_output": false,
    "execute_requires_force": true,
    "force_cannot_enable_network": true
  },
  "must_not_echo": [
    "plain-password",
    "fixture-api-secret",
    "fixture-bearer-secret",
    "Bearer fixture-bearer-secret",
    "ops-user",
    "raw_payload"
  ],
  "remaining_gaps": [
    "real_clickhouse_writer",
    "database_changefeed_or_export_cursor",
    "durable_wal_writer",
    "dedup_journal_runtime_persistence",
    "load_and_retention_smoke"
  ]
}
