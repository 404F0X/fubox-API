{
  "todo": "E1-004",
  "scope": "control-plane provider, channel, api_key_profile, canonical model, model_association, provider_key and price_version admin writes plus read-only audit log query API",
  "transaction_contract": {
    "business_and_audit_share_transaction": true,
    "paths": [
      "POST /admin/providers",
      "PATCH /admin/providers/{id}",
      "DELETE /admin/providers/{id}",
      "POST /admin/channels",
      "PATCH /admin/channels/{id}",
      "DELETE /admin/channels/{id}",
      "POST /admin/api-key-profiles",
      "PATCH /admin/api-key-profiles/{id}",
      "DELETE /admin/api-key-profiles/{id}",
      "POST /admin/models",
      "PATCH /admin/models/{id}",
      "DELETE /admin/models/{id}",
      "POST /admin/model-associations",
      "PATCH /admin/model-associations/{id}",
      "DELETE /admin/model-associations/{id}",
      "POST /admin/provider-keys",
      "PATCH /admin/provider-keys/{id}",
      "DELETE /admin/provider-keys/{id}",
      "POST /admin/price-versions"
    ],
    "failure_behavior": "business write and success audit are committed together; missing business rows do not build success audit; audit insert failure rolls back the provider, channel, api_key_profile, canonical model, model_association, provider_key or price_version write"
  },
  "metadata_contract": {
    "raw_request_body_omitted": true,
    "raw_headers_omitted": true,
    "raw_user_agent_omitted": true,
    "raw_client_ip_omitted": true,
    "request_context_fields": [
      "user_agent_sha256",
      "user_agent_length",
      "client_ip_sha256",
      "client_ip_source",
      "client_ip_kind",
      "client_ip_scope"
    ]
  },
  "query_contract": {
    "path": "GET /admin/audit-logs",
    "required_permission": "audit_read",
    "tenant_scoped": true,
    "filters": [
      "tenant_id",
      "actor_user_id",
      "actor_session_id",
      "action",
      "resource_type",
      "resource_id",
      "resource_tenant_id",
      "created_from",
      "created_to",
      "limit"
    ],
    "default_limit": 50,
    "max_limit": 500,
    "response_secret_safe": true,
    "omits_or_redacts": [
      "auth headers",
      "cookies",
      "payload",
      "body",
      "raw headers",
      "provider endpoint or base_url",
      "provider key material"
    ]
  },
