{
  "scenario": "control_plane_admin_auth_rbac_smoke",
  "base_path": "/admin",
  "auth_endpoints": {
    "login": {
      "method": "POST",
      "path": "/admin/auth/login",
      "public": true,
      "request_fields": ["email", "password"],
      "response_token_field": "data.session_token_once",
      "failure_rate_limit": {
        "key": "tenant_id + normalized_email_fingerprint",
        "default_threshold": 5,
        "default_window_seconds": 300,
        "limited_status": 429,
        "limited_error_code": "login_rate_limited",
        "retry_after_header": "Retry-After",
        "invalid_credentials_error_code": "invalid_credentials",
        "success_clears_failures": true,
        "does_not_reveal_user_existence": true,
        "does_not_store_raw_username": true,
        "store_env": "AI_GATEWAY_ADMIN_LOGIN_RATE_LIMIT_STORE",
        "default_store": "memory",
        "redis_distributed_store": {
          "status": "minimal_runtime_backend",
          "enabled_values": ["redis", "distributed_redis"],
          "redis_addr_source": "config.redis.addr",
          "redis_db_source": "config.redis.db",
          "key_prefix_env": "AI_GATEWAY_ADMIN_LOGIN_RATE_LIMIT_REDIS_KEY_PREFIX",
          "timeout_ms_env": "AI_GATEWAY_ADMIN_LOGIN_RATE_LIMIT_REDIS_TIMEOUT_MS",
          "default_timeout_ms": 200,
          "key_material": "tenant_id + normalized_email_fingerprint",
          "raw_username_stored": false,
          "atomic_record_failure": "redis EVAL + SET EX",
          "success_clear": "DEL",
          "unavailable_policy": "fail_closed",
          "unavailable_status": 429,
          "unavailable_error_code": "login_rate_limited",
          "unavailable_response_echoes_username_or_credentials": false
        }
      }
    },
    "oidc_authorize_url": {
      "method": "GET",
      "path": "/admin/auth/oidc/authorize-url",
      "public": true,
      "response_fields": [
        "data.authorization_url",
        "data.state",
        "data.nonce",
        "data.server_state_persisted",
        "data.callback_implemented"
      ],
      "contract": {
        "response_type": "code",
        "server_state_persisted": false,
        "callback_implemented": false,
        "state_and_nonce_randomized": true,
        "scope_requires_openid": true
      }
    },
    "oidc_callback": {
      "method": "GET",
      "path": "/admin/auth/oidc/callback",
      "public": true,
      "expected_status": 400,
      "accepted_login": false,
      "error_codes": [
        "oidc_state_not_persisted",
        "oidc_claims_not_accepted"
      ],
      "security_boundaries": {
        "requires_server_side_state_and_nonce": true,
        "code_exchange_implemented": false,
        "jwks_id_token_validation_implemented": false,
        "direct_claims_login_accepted": false,
        "error_body_must_not_echo": [
          "provider_config",
          "code",
          "id_token",
          "access_token",
          "claims"
        ]
      }
    },
    "me": {
      "method": "GET",
      "path": "/admin/auth/me",
      "requires_session": true,
      "response_fields": [
        "data.user",
        "data.session",
        "data.capability_summary.capabilities",
        "data.capability_summary.denied_capabilities",
        "data.capability_summary.secret_safe"
      ],
      "forbidden_response_fields": [
        "data.session_token_once",
        "data.password_hash",
        "data.permissions"
      ]
    },
    "logout": {
      "method": "POST",
      "path": "/admin/auth/logout",
      "requires_session": true
    }
  },
  "protected_no_session": {
    "method": "GET",
    "path": "/admin/providers",
    "expected_status": 401,
    "expected_error_code": "unauthorized"
  },
  "dev_admin_session_prereqs": {
    "diagnostic_default": true,
    "repair_flag": "-RepairDevAdminSessionPrereqs",
    "repair_env": "CONTROL_PLANE_AUTH_SMOKE_REPAIR_DEV_ADMIN_SESSION_PREREQS",
    "blocked_exit_code": 2,
    "required_tables": ["user_sessions"],
    "required_seed_files": [
      "db/dev-seeds/0001_dev_admin_seed.sql",
      "db/dev-seeds/0003_dev_smoke_seed_reconcile.sql"
    ],
    "required_migration": "db/migrations/0005_e1_e2_e3_e10_integrity_hardening.sql",
    "missing_markers": [
      "user_sessions_migration_missing",
      "dev_admin_user_missing",
      "dev_admin_team_owner_missing",
      "dev_admin_project_owner_missing"
    ],
    "secret_safe_output": {
      "session_token_echoed": false,
      "cookie_echoed": false,
      "password_hash_echoed": false
    }
  },
  "runtime_source_mismatch_diagnostic": {
    "diagnostic_default": true,
    "does_not_trigger_build": true,
    "non_blocking_marker": "runtime_image_stale_or_unverified",
    "probe": "control_plane_image_timestamp",
    "runtime_current_handoff": {
      "marker": "runtime_current_handoff",
      "mode": "control_plane_no_build_recreate",
      "command_contains": [
        "docker compose",
        "--no-build",
        "--no-deps",
        "--force-recreate",
        "control-plane"
      ],
      "build_allowed": false,
      "blocked_when_source_newer_than_image": true,
      "source_newer_blocker": "runtime_image_requires_rebuild_but_build_forbidden"
    },
    "stale_or_unverified_reasons": [
      "source_newer_than_runtime_image",
      "control_plane_container_unavailable",
      "control_plane_image_inspect_unavailable",
      "docker_unavailable",
      "source_timestamp_unavailable"
    ],
    "secret_safe_output": {
      "token_echoed": false,
      "cookie_echoed": false,
      "dsn_echoed": false,
      "raw_env_echoed": false
    }
  },
  "optional_role_denials": [
    {
      "name": "viewer_provider_write_denied",
      "role": "viewer",
      "permission": "provider_manage",
      "method": "PATCH",
      "path": "/admin/providers/00000000-0000-0000-0000-000000000000",
      "expected_status": 403,
      "expected_error_code": "forbidden",
      "body": {
        "name": "auth smoke denied probe"
      }
    }
  ],
  "notes": "Live smoke verifies real admin login, /admin/auth/me secret-safe capability summary, logout, and post-logout 401. Viewer 403 is optional unless strict mode is enabled because the dev seed only guarantees the owner admin account."
}
