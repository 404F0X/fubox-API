  "request_contract": {
    "required_fields": ["project_id", "profile_id"],
    "model_selector_any_of": ["requested_model", "canonical_model_id", "canonical_model_key"],
    "optional_fields": ["seed", "trace_id", "previous_successful_channel_id"]
