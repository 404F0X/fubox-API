{
  "todo": "E3-004",
  "scenario": "control_plane_provider_key_status_contract",
  "base_path": "/admin",
  "read_contract": {
    "path": "GET /admin/provider-keys/{id}",
    "response_envelope": "data",
    "credential_material_omitted": true,
    "runtime_window_state_omitted": true,
    "public_credential_indicator": "credential_configured",
    "forbidden_response_fields": [
      "secret",
      "api_key",
      "encrypted_secret",
      "secret_fingerprint",
      "has_secret_fingerprint",
      "current_window_state",
      "Authorization",
      "authorization",
      "raw_endpoint",
      "endpoint",
      "raw_payload",
      "payload",
      "metadata"
    ],
    "required_safe_readback_fields": [
      "lifecycle_state",
      "credential_generation",
      "last_probe_summary",
      "rotation_needed",
      "safe_next_action",
      "omitted_secret_policy"
    ]
  },
  "patch_contract": {
    "path": "PATCH /admin/provider-keys/{id}",
    "allowed_target_statuses": [
      "enabled",
      "manual_disabled",
      "degraded",
      "recovery_probe"
    ],
    "normalized_aliases": {
      "active": "enabled",
      "disabled": "manual_disabled"
    },
    "forbidden_direct_target_statuses": [
      "auth_failed",
      "quota_exhausted",
      "cooldown",
      "deleted"
    ],
    "runtime_managed_statuses": [
      "auth_failed",
      "quota_exhausted",
      "cooldown"
    ],
    "secret_update_fields_rejected": [
      "secret",
      "api_key",
      "encrypted_secret",
      "secret_fingerprint"
    ],
    "metadata_secret_fields_rejected": true,
    "audit_secret_safe": true
  },
  "rotation_contract": {
    "path": "POST /admin/provider-keys/{id}/rotate",
    "required_permission": "key_manage",
    "request_secret_field": "secret",
    "caller_encrypted_secret_rejected": true,
    "server_seals_secret": true,
    "encrypted_at_rest_algorithm": "aes-256-gcm",
    "fingerprint_only_public": true,
    "old_key_transition": {
      "from_status": "enabled",
      "to_status": "manual_disabled",
      "reason": "rotated"
    },
    "new_key_transition": {
      "from_status": "pending_create",
      "to_status": "enabled"
    },
    "audit_action": "provider_key.rotate",
    "audit_secret_safe": true,
    "response_omits": [
      "secret",
      "api_key",
      "encrypted_secret",
      "secret_fingerprint",
      "current_window_state",
      "Authorization",
      "raw_endpoint",
      "raw_payload"
    ],
    "response_requires": [
      "lifecycle_state",
      "credential_generation",
      "last_probe_summary",
      "rotation_needed.reason",
      "safe_next_action",
      "omitted_secret_policy"
    ]
  },
  "view_audit_contract": {
    "list_get_never_return_secret": true,
    "read_audit_action": "provider_key.view",
    "audit_metadata_allowed_identifiers": [
      "provider_key_id",
      "tenant_id",
      "channel_id",
      "key_alias"
    ],
    "audit_metadata_forbidden_values": [
      "secret",
      "api_key",
      "encrypted_secret",
      "secret_fingerprint",
      "authorization",
      "bearer"
    ],
    "fingerprint_never_returned": true,
    "credential_configured_is_only_public_indicator": true
  },
  "recovery_contract": {
    "path": "POST /admin/provider-keys/{id}/recovery",
    "required_permission": "key_manage",
    "allowed_source_statuses": [
      "cooldown",
      "degraded",
      "recovery_probe"
    ],
    "allowed_target_statuses": [
      "recovery_probe",
      "enabled"
    ],
    "default_target_status": "recovery_probe",
    "forbidden_source_statuses": [
      "auth_failed",
      "quota_exhausted",
      "manual_disabled",
      "enabled",
      "deleted"
    ],
    "forbidden_target_statuses": [
      "auth_failed",
      "quota_exhausted",
      "cooldown",
      "manual_disabled",
      "degraded",
      "deleted"
    ],
    "unknown_fields_rejected": true,
    "upstream_probe_executed": false,
    "recovery_apply_plan_readback": true,
    "billable": false,
    "audit_action": "provider_key.recovery_request",
    "audit_secret_safe": true
  },
