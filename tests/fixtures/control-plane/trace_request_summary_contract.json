    "payload_material_omitted": true,
    "secret_material_redacted": true,
    "allowed_payload_metadata": [
      "payload_policy_id",
      "payload_stored",
      "redaction_status",
      "request_body_hash",
      "response_body_hash"
    ],
    "disallowed_response_fields": [
      "payload_object_ref",
      "payload",
      "body",
      "request_body",
      "response_body",
      "route_decision_snapshot"
    ]
  },
