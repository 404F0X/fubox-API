{
  "scenario": "control_plane_trace_request_summary_contract",
  "base_path": "/admin",
  "endpoint": {
    "method": "GET",
    "path": "/admin/traces/{trace_id}",
    "example_path": "/admin/traces/trace-contract-1",
    "query": {
      "limit": 2
    }
  },
  "response_contract": {
    "envelope": "data",
    "read_only": true,
    "tenant_scoped": true,
    "rbac_permission": "log_read_metadata",
    "limit": {
      "default": 50,
      "maximum": 500,
      "minimum": 1,
      "zero_or_negative": "bad_request",
      "above_maximum": "capped_to_500"
