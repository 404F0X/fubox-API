  "expected_sql_fragments": {
    "acquire": [
      "from provider_keys",
      "where tenant_id = $1",
      "and id = $2",
      "and channel_id = $3",
      "and deleted_at is null",
      "for update",
      "(rpm_limit is not null and $4::bigint > 0)",
      "(tpm_limit is not null and $5::bigint > 0)",
      "(concurrency_limit is not null and $6::bigint > 0)",
      "and rpm_used + $4::bigint <= rpm_limit",
      "and tpm_used + $5::bigint <= tpm_limit",
      "and concurrency_used + $6::bigint <= concurrency_limit",
      "jsonb_set(pk.current_window_state, '{rpm,used}'",
      "to_jsonb(eligible.rpm_used + $4::bigint)",
      "returning"
    ],
    "release": [
      "from provider_keys",
      "where tenant_id = $1",
      "and id = $2",
      "and channel_id = $3",
      "and $7::boolean = true",
      "for update",
      "(rpm_limit is not null and $4::bigint > 0)",
      "(tpm_limit is not null and $5::bigint > 0)",
      "(concurrency_limit is not null and $6::bigint > 0)",
      "greatest(eligible.rpm_used - $4::bigint, 0)",
      "greatest(eligible.tpm_used - $5::bigint, 0)",
      "greatest(eligible.concurrency_used - $6::bigint, 0)",
      "returning"
    ]
  },
