# OpenTelemetry is disabled by default. Leave these unset for the current
# Prometheus-only local path.
AI_GATEWAY_OTEL_EXPORTER=disabled

# Local stdout/console exporter shape for smoke testing without a collector.
# AI_GATEWAY_OTEL_EXPORTER=stdout

# OTLP exporter shape. HTTP endpoints are validated and must not include query
# strings, fragments, user info, or embedded credentials.
# AI_GATEWAY_OTEL_EXPORTER=otlp
# AI_GATEWAY_OTEL_ENDPOINT=http://localhost:4318/v1/traces

# Standard OTEL variables are also accepted.
# OTEL_TRACES_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=ai-gateway
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,service.version=0.1.0-alpha
