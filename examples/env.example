AI_GATEWAY_CONFIG=./examples/config.example.yaml
AI_GATEWAY_MASTER_KEY=change-me
AI_GATEWAY_LOG_LEVEL=info
AI_GATEWAY_ENV=development
AI_GATEWAY_LISTEN=0.0.0.0:8080
AI_GATEWAY_CONTROL_LISTEN=0.0.0.0:8081
AI_GATEWAY_PROVIDER_KEY_MASTER_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
AI_GATEWAY_PROVIDER_KEY_MASTER_KEY_ID=dev-seed-v1
AI_GATEWAY_CONTROL_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set AI_GATEWAY_ADMIN_COOKIE_SECURE=false only for local HTTP development.
# Omit it or set true for HTTPS production.
# VITE_* values are build-time settings for the Vite dev server or explicit
# browser-reachable API origins. The production admin-ui image uses the
# runtime *_UPSTREAM variables below and same-origin /api/* proxy paths.
VITE_GATEWAY_BASE_URL=http://localhost:8080
VITE_CONTROL_BASE_URL=http://localhost:8081
VITE_MOCK_PROVIDER_BASE_URL=http://localhost:18080
ADMIN_UI_PORT=8080
GATEWAY_UPSTREAM=http://gateway:8080
CONTROL_PLANE_UPSTREAM=http://control-plane:8081
MOCK_PROVIDER_UPSTREAM=http://mock-provider:18080

# Optional external virtual-key leak scanner adapter readback.
# Values are presence/readiness markers only; do not put raw tokens,
# Authorization headers, raw findings, or webhook secrets in docs/artifacts.
# AI_GATEWAY_VIRTUAL_KEY_SCANNER_PROVIDER=github_secret_scanning
# AI_GATEWAY_VIRTUAL_KEY_SCANNER_STATUS=config-needed
# AI_GATEWAY_VIRTUAL_KEY_SCANNER_ENDPOINT_REF=
# AI_GATEWAY_VIRTUAL_KEY_SCANNER_SECRET_REF=
# AI_GATEWAY_VIRTUAL_KEY_SCANNER_WEBHOOK_REF=
# AI_GATEWAY_VIRTUAL_KEY_SCANNER_SYNC_DIRECTION=external_to_control_plane_metadata_only
